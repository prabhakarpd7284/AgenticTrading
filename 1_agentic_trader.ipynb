    "   \"source\": [\n",
    "    \"\\\"\\\"\\\"\\n\",\n",
    "    \"Agentic Intraday Trading Workflow using LangGraph\\n\",\n",
    "    \"Strategy: Buy on new intraday high, Stop-loss at day low\\n\",\n",
    "    \"\\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"from typing import TypedDict, Annotated, List, Optional\\n\",\n",
    "    \"from datetime import datetime, time\\n\",\n",
    "    \"from enum import Enum\\n\",\n",
    "    \"import operator\\n\",\n",
    "    \"from langgraph.graph import StateGraph, END\\n\",\n",
    "    \"from langgraph.checkpoint.memory import MemorySaver\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ============================================================================\\n\",\n",
    "    \"# STATE DEFINITION\\n\",\n",
    "    \"# ============================================================================\\n\",\n",
    "    \"\\n\",\n",
    "    \"class PositionStatus(Enum):\\n\",\n",
    "    \"    NO_POSITION = \\\"no_position\\\"\\n\",\n",
    "    \"    LONG = \\\"long\\\"\\n\",\n",
    "    \"    EXITED = \\\"exited\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class TradeState(TypedDict):\\n\",\n",
    "    \"    \\\"\\\"\\\"Complete state of the trading system\\\"\\\"\\\"\\n\",\n",
    "    \"    # Market Data\\n\",\n",
    "    \"    current_price: float\\n\",\n",
    "    \"    current_time: datetime\\n\",\n",
    "    \"    intraday_high: float\\n\",\n",
    "    \"    intraday_low: float\\n\",\n",
    "    \"    day_open: float\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Position Information\\n\",\n",
    "    \"    position_status: PositionStatus\\n\",\n",
    "    \"    entry_price: Optional[float]\\n\",\n",
    "    \"    quantity: int\\n\",\n",
    "    \"    stop_loss: float\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # PnL Tracking\\n\",\n",
    "    \"    realized_pnl: float\\n\",\n",
    "    \"    unrealized_pnl: float\\n\",\n",
    "    \"    total_pnl: float\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Decision History\\n\",\n",
    "    \"    decision_points: Annotated[List[dict], operator.add]\\n\",\n",
    "    \"    trade_log: Annotated[List[dict], operator.add]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Control Flags\\n\",\n",
    "    \"    market_open: bool\\n\",\n",
    "    \"    should_continue: bool\\n\",\n",
    "    \"    error_message: Optional[str]\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ============================================================================\\n\",\n",
    "    \"# AGENT NODES\\n\",\n",
    "    \"# ============================================================================\\n\",\n",
    "    \"\\n\",\n",
    "    \"class MarketDataAgent:\\n\",\n",
    "    \"    \\\"\\\"\\\"Fetches and processes market data from broker API\\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __init__(self, broker_api):\\n\",\n",
    "    \"        self.broker_api = broker_api\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __call__(self, state: TradeState) -> TradeState:\\n\",\n",
    "    \"        \\\"\\\"\\\"Fetch latest market data and update state\\\"\\\"\\\"\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            # Fetch from broker API (replace with actual API call)\\n\",\n",
    "    \"            data = self.broker_api.get_live_data()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            current_price = data['ltp']\\n\",\n",
    "    \"            current_time = datetime.now()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Update intraday high/low\\n\",\n",
    "    \"            intraday_high = max(state.get('intraday_high', 0), current_price)\\n\",\n",
    "    \"            intraday_low = min(state.get('intraday_low', float('inf')), current_price-0.5)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Check market hours (9:15 AM to 3:30 PM IST for example)\\n\",\n",
    "    \"            # market_open = time(9, 15) <= current_time.time() <= time(15, 30)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            return {\\n\",\n",
    "    \"                **state,\\n\",\n",
    "    \"                'current_price': current_price,\\n\",\n",
    "    \"                'current_time': current_time,\\n\",\n",
    "    \"                'intraday_high': intraday_high,\\n\",\n",
    "    \"                'intraday_low': intraday_low,\\n\",\n",
    "    \"                # 'market_open': market_open,\\n\",\n",
    "    \"                'error_message': None\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"\\n\",\n",
    "    \"        except Exception as e:\\n\",\n",
    "    \"            return {\\n\",\n",
    "    \"                **state,\\n\",\n",
    "    \"                'error_message': f\\\"Market data fetch failed: {str(e)}\\\",\\n\",\n",
    "    \"                'should_continue': False\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class SignalGeneratorAgent:\\n\",\n",
    "    \"    \\\"\\\"\\\"Detects new intraday highs and generates trading signals\\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __call__(self, state: TradeState) -> TradeState:\\n\",\n",
    "    \"        \\\"\\\"\\\"Check if current price makes new intraday high\\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"        current_price = state['current_price']\\n\",\n",
    "    \"        prev_high = state.get('intraday_high', 0)\\n\",\n",
    "    \"        position_status = state.get('position_status', PositionStatus.NO_POSITION)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Signal: New intraday high AND no existing position\\n\",\n",
    "    \"        new_high_signal = (\\n\",\n",
    "    \"            current_price >= state['intraday_high'] and\\n\",\n",
    "    \"            position_status == PositionStatus.NO_POSITION and\\n\",\n",
    "    \"            state['market_open']\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        decision_point = {\\n\",\n",
    "    \"            'timestamp': state['current_time'].isoformat(),\\n\",\n",
    "    \"            'price': current_price,\\n\",\n",
    "    \"            'intraday_high': state['intraday_high'],\\n\",\n",
    "    \"            'intraday_low': state['intraday_low'],\\n\",\n",
    "    \"            'signal': 'BUY' if new_high_signal else 'HOLD',\\n\",\n",
    "    \"            'reason': 'New intraday high detected' if new_high_signal else 'No signal'\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return {\\n\",\n",
    "    \"            **state,\\n\",\n",
    "    \"            'decision_points': [decision_point]\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class RiskManagerAgent:\\n\",\n",
    "    \"    \\\"\\\"\\\"Calculates position size, stop-loss, and risk parameters\\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __init__(self, capital: float, risk_per_trade: float = 0.02):\\n\",\n",
    "    \"        self.capital = capital\\n\",\n",
    "    \"        self.risk_per_trade = risk_per_trade  # 2% risk per trade\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __call__(self, state: TradeState) -> TradeState:\\n\",\n",
    "    \"        \\\"\\\"\\\"Calculate position size and stop-loss\\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"        entry_price = state['current_price']\\n\",\n",
    "    \"        stop_loss = state['intraday_low']\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Calculate position size based on risk\\n\",\n",
    "    \"        risk_amount = self.capital * self.risk_per_trade\\n\",\n",
    "    \"        price_risk_per_share = entry_price - stop_loss\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if price_risk_per_share > 0:\\n\",\n",
    "    \"            quantity = int(risk_amount / price_risk_per_share)\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            quantity = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return {\\n\",\n",
    "    \"            **state,\\n\",\n",
    "    \"            'stop_loss': stop_loss,\\n\",\n",
    "    \"            'quantity': quantity\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class TradeExecutorAgent:\\n\",\n",
    "    \"    \\\"\\\"\\\"Executes trades via broker API\\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __init__(self, broker_api):\\n\",\n",
    "    \"        self.broker_api = broker_api\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def execute_buy(self, state: TradeState) -> TradeState:\\n\",\n",
    "    \"        \\\"\\\"\\\"Execute buy order\\\"\\\"\\\"\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            # Place buy order via broker API\\n\",\n",
    "    \"            order = self.broker_api.place_order(\\n\",\n",
    "    \"                side='BUY',\\n\",\n",
    "    \"                quantity=state['quantity'],\\n\",\n",
    "    \"                price=state['current_price']\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"            trade_log_entry = {\\n\",\n",
    "    \"                'timestamp': state['current_time'].isoformat(),\\n\",\n",
    "    \"                'action': 'BUY',\\n\",\n",
    "    \"                'price': state['current_price'],\\n\",\n",
    "    \"                'quantity': state['quantity'],\\n\",\n",
    "    \"                'order_id': order.get('order_id')\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"\\n\",\n",
    "    \"            return {\\n\",\n",
    "    \"                **state,\\n\",\n",
    "    \"                'position_status': PositionStatus.LONG,\\n\",\n",
    "    \"                'entry_price': state['current_price'],\\n\",\n",
    "    \"                'trade_log': [trade_log_entry]\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"\\n\",\n",
    "    \"        except Exception as e:\\n\",\n",
    "    \"            return {\\n\",\n",
    "    \"                **state,\\n\",\n",
    "    \"                'error_message': f\\\"Buy order failed: {str(e)}\\\"\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def execute_sell(self, state: TradeState) -> TradeState:\\n\",\n",
    "    \"        \\\"\\\"\\\"Execute sell order\\\"\\\"\\\"\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            # Place sell order via broker API\\n\",\n",
    "    \"            order = self.broker_api.place_order(\\n\",\n",
    "    \"                side='SELL',\\n\",\n",
    "    \"                quantity=state['quantity'],\\n\",\n",
    "    \"                price=state['current_price']\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Calculate realized PnL\\n\",\n",
    "    \"            pnl = (state['current_price'] - state['entry_price']) * state['quantity']\\n\",\n",
    "    \"\\n\",\n",
    "    \"            trade_log_entry = {\\n\",\n",
    "    \"                'timestamp': state['current_time'].isoformat(),\\n\",\n",
    "    \"                'action': 'SELL',\\n\",\n",
    "    \"                'price': state['current_price'],\\n\",\n",
    "    \"                'quantity': state['quantity'],\\n\",\n",
    "    \"                'pnl': pnl,\\n\",\n",
    "    \"                'order_id': order.get('order_id')\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"\\n\",\n",
    "    \"            return {\\n\",\n",
    "    \"                **state,\\n\",\n",
    "    \"                'position_status': PositionStatus.EXITED,\\n\",\n",
    "    \"                'realized_pnl': state['realized_pnl'] + pnl,\\n\",\n",
    "    \"                'total_pnl': state['total_pnl'] + pnl,\\n\",\n",
    "    \"                'unrealized_pnl': 0,\\n\",\n",
    "    \"                'trade_log': [trade_log_entry]\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"\\n\",\n",
    "    \"        except Exception as e:\\n\",\n",
    "    \"            return {\\n\",\n",
    "    \"                **state,\\n\",\n",
    "    \"                'error_message': f\\\"Sell order failed: {str(e)}\\\"\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class PnLTrackerAgent:\\n\",\n",
    "    \"    \\\"\\\"\\\"Tracks running profit and loss\\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __call__(self, state: TradeState) -> TradeState:\\n\",\n",
    "    \"        \\\"\\\"\\\"Update unrealized PnL for open positions\\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if state['position_status'] == PositionStatus.LONG:\\n\",\n",
    "    \"            unrealized_pnl = (\\n\",\n",
    "    \"                (state['current_price'] - state['entry_price']) * state['quantity']\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"            total_pnl = state['realized_pnl'] + unrealized_pnl\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            unrealized_pnl = 0\\n\",\n",
    "    \"            total_pnl = state['realized_pnl']\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return {\\n\",\n",
    "    \"            **state,\\n\",\n",
    "    \"            'unrealized_pnl': unrealized_pnl,\\n\",\n",
    "    \"            'total_pnl': total_pnl\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class DecisionAgent:\\n\",\n",
    "    \"    \\\"\\\"\\\"Makes hold/exit decisions based on current state\\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __init__(self, profit_target_pct: float = 0.015):\\n\",\n",
    "    \"        self.profit_target_pct = profit_target_pct  # 1.5% profit target\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __call__(self, state: TradeState) -> TradeState:\\n\",\n",
    "    \"        \\\"\\\"\\\"Decide whether to hold, book profits, or exit\\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if state['position_status'] != PositionStatus.LONG:\\n\",\n",
    "    \"            return state\\n\",\n",
    "    \"\\n\",\n",
    "    \"        current_price = state['current_price']\\n\",\n",
    "    \"        entry_price = state['entry_price']\\n\",\n",
    "    \"        stop_loss = state['intraday_low']  # Trailing stop at day low\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Exit conditions\\n\",\n",
    "    \"        hit_stop_loss = current_price <= stop_loss\\n\",\n",
    "    \"        profit_pct = ((current_price - entry_price) / entry_price) if entry_price > 0.0 else 0\\n\",\n",
    "    \"        hit_profit_target = profit_pct >= self.profit_target_pct\\n\",\n",
    "    \"        market_closing = not state['market_open']\\n\",\n",
    "    \"\\n\",\n",
    "    \"        should_exit = hit_stop_loss or hit_profit_target or market_closing\\n\",\n",
    "    \"\\n\",\n",
    "    \"        exit_reason = None\\n\",\n",
    "    \"        if hit_stop_loss:\\n\",\n",
    "    \"            exit_reason = \\\"Stop-loss hit\\\"\\n\",\n",
    "    \"        elif hit_profit_target:\\n\",\n",
    "    \"            exit_reason = \\\"Profit target reached\\\"\\n\",\n",
    "    \"        elif market_closing:\\n\",\n",
    "    \"            exit_reason = \\\"Market closing\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"        decision = {\\n\",\n",
    "    \"            'timestamp': state['current_time'].isoformat(),\\n\",\n",
    "    \"            'decision': 'EXIT' if should_exit else 'HOLD',\\n\",\n",
    "    \"            'reason': exit_reason if should_exit else 'Holding position',\\n\",\n",
    "    \"            'current_price': current_price,\\n\",\n",
    "    \"            'stop_loss': stop_loss,\\n\",\n",
    "    \"            'unrealized_pnl': state['unrealized_pnl']\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return {\\n\",\n",
    "    \"            **state,\\n\",\n",
    "    \"            'stop_loss': stop_loss,  # Update trailing stop\\n\",\n",
    "    \"            'decision_points': [decision],\\n\",\n",
    "    \"            'should_continue': not should_exit\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ============================================================================\\n\",\n",
    "    \"# WORKFLOW DEFINITION\\n\",\n",
    "    \"# ============================================================================\\n\",\n",
    "    \"\\n\",\n",
    "    \"class IntradayTradingWorkflow:\\n\",\n",
    "    \"    \\\"\\\"\\\"LangGraph workflow for intraday trading\\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __init__(self, broker_api, capital: float = 100000):\\n\",\n",
    "    \"        self.broker_api = broker_api\\n\",\n",
    "    \"        self.capital = capital\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Initialize agents\\n\",\n",
    "    \"        self.market_data = MarketDataAgent(broker_api)\\n\",\n",
    "    \"        self.signal_gen = SignalGeneratorAgent()\\n\",\n",
    "    \"        self.risk_mgr = RiskManagerAgent(capital)\\n\",\n",
    "    \"        self.executor = TradeExecutorAgent(broker_api)\\n\",\n",
    "    \"        self.pnl_tracker = PnLTrackerAgent()\\n\",\n",
    "    \"        self.decision = DecisionAgent()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Build graph\\n\",\n",
    "    \"        self.graph = self._build_graph()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _build_graph(self) -> StateGraph:\\n\",\n",
    "    \"        \\\"\\\"\\\"Construct the LangGraph workflow\\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"        workflow = StateGraph(TradeState)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Add nodes\\n\",\n",
    "    \"        workflow.add_node(\\\"fetch_data\\\", self.market_data)\\n\",\n",
    "    \"        workflow.add_node(\\\"generate_signal\\\", self.signal_gen)\\n\",\n",
    "    \"        workflow.add_node(\\\"assess_risk\\\", self.risk_mgr)\\n\",\n",
    "    \"        workflow.add_node(\\\"execute_buy\\\", self.executor.execute_buy)\\n\",\n",
    "    \"        workflow.add_node(\\\"track_pnl\\\", self.pnl_tracker)\\n\",\n",
    "    \"        workflow.add_node(\\\"make_decision\\\", self.decision)\\n\",\n",
    "    \"        workflow.add_node(\\\"execute_sell\\\", self.executor.execute_sell)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Define edges\\n\",\n",
    "    \"        workflow.set_entry_point(\\\"fetch_data\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Route from signal generation\\n\",\n",
    "    \"        def route_after_signal(state: TradeState) -> str:\\n\",\n",
    "    \"            last_decision = state['decision_points'][-1]\\n\",\n",
    "    \"            if last_decision['signal'] == 'BUY':\\n\",\n",
    "    \"                return \\\"assess_risk\\\"\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                return \\\"track_pnl\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"        workflow.add_edge(\\\"fetch_data\\\", \\\"generate_signal\\\")\\n\",\n",
    "    \"        workflow.add_conditional_edges(\\n\",\n",
    "    \"            \\\"generate_signal\\\",\\n\",\n",
    "    \"            route_after_signal,\\n\",\n",
    "    \"            {\\\"assess_risk\\\": \\\"assess_risk\\\", \\\"track_pnl\\\": \\\"track_pnl\\\"}\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        workflow.add_edge(\\\"assess_risk\\\", \\\"execute_buy\\\")\\n\",\n",
    "    \"        workflow.add_edge(\\\"execute_buy\\\", \\\"track_pnl\\\")\\n\",\n",
    "    \"        workflow.add_edge(\\\"track_pnl\\\", \\\"make_decision\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Route from decision\\n\",\n",
    "    \"        def route_after_decision(state: TradeState) -> str:\\n\",\n",
    "    \"            last_decision = state['decision_points'][-1]\\n\",\n",
    "    \"            if last_decision['decision'] == 'EXIT':\\n\",\n",
    "    \"                return \\\"execute_sell\\\"\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                return END\\n\",\n",
    "    \"\\n\",\n",
    "    \"        workflow.add_conditional_edges(\\n\",\n",
    "    \"            \\\"make_decision\\\",\\n\",\n",
    "    \"            route_after_decision,\\n\",\n",
    "    \"            {\\\"execute_sell\\\": \\\"execute_sell\\\", END: END}\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        workflow.add_edge(\\\"execute_sell\\\", END)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Compile with memory\\n\",\n",
    "    \"        memory = MemorySaver()\\n\",\n",
    "    \"        return workflow.compile(checkpointer=memory)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def initialize_state(self) -> TradeState:\\n\",\n",
    "    \"        \\\"\\\"\\\"Initialize trading state at market open\\\"\\\"\\\"\\n\",\n",
    "    \"        return TradeState(\\n\",\n",
    "    \"            current_price=0.0,\\n\",\n",
    "    \"            current_time=datetime.now(),\\n\",\n",
    "    \"            intraday_high=0.0,\\n\",\n",
    "    \"            intraday_low=float('inf'),\\n\",\n",
    "    \"            day_open=0.0,\\n\",\n",
    "    \"            position_status=PositionStatus.NO_POSITION,\\n\",\n",
    "    \"            entry_price=None,\\n\",\n",
    "    \"            quantity=0,\\n\",\n",
    "    \"            stop_loss=0.0,\\n\",\n",
    "    \"            realized_pnl=0.0,\\n\",\n",
    "    \"            unrealized_pnl=0.0,\\n\",\n",
    "    \"            total_pnl=0.0,\\n\",\n",
    "    \"            decision_points=[],\\n\",\n",
    "    \"            trade_log=[],\\n\",\n",
    "    \"            market_open=True,\\n\",\n",
    "    \"            should_continue=True,\\n\",\n",
    "    \"            error_message=None\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def run_tick(self, state: TradeState, config: dict) -> TradeState:\\n\",\n",
    "    \"        \\\"\\\"\\\"Execute one trading tick\\\"\\\"\\\"\\n\",\n",
    "    \"        result = self.graph.invoke(state, config)\\n\",\n",
    "    \"        return result\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ============================================================================\\n\",\n",
    "    \"# USAGE EXAMPLE\\n\",\n",
    "    \"# ============================================================================\\n\",\n",
    "    \"\\n\",\n",
    "    \"if __name__ == \\\"__main__\\\":\\n\",\n",
    "    \"    # Mock broker API (replace with actual implementation)\\n\",\n",
    "    \"    class MockBrokerAPI:\\n\",\n",
    "    \"        def get_live_data(self):\\n\",\n",
    "    \"            import random\\n\",\n",
    "    \"            return {'ltp': 100 + random.uniform(0.1, 20)}\\n\",\n",
    "    \"\\n\",\n",
    "    \"        def place_order(self, side, quantity, price):\\n\",\n",
    "    \"            return {'order_id': f'ORD_{datetime.now().timestamp()}'}\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Initialize workflow\\n\",\n",
    "    \"    broker = MockBrokerAPI()\\n\",\n",
    "    \"    workflow = IntradayTradingWorkflow(broker, capital=100000)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Initialize state\\n\",\n",
    "    \"    state = workflow.initialize_state()\\n\",\n",
    "    \"    config = {\\\"configurable\\\": {\\\"thread_id\\\": \\\"trading_session_1\\\"}}\\n\",\n",
    "    \"    display(Image(workflow.graph.get_graph().draw_mermaid_png()))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Run trading loop (simplified - in production, use event-driven)\\n\",\n",
    "    \"    import time\\n\",\n",
    "    \"    for tick in range(10):\\n\",\n",
    "    \"        print(f\\\"\\\\n=== Tick {tick + 1} ===\\\")\\n\",\n",
    "    \"        state = workflow.run_tick(state, config)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(f\\\"Price: {state['current_price']:.2f}\\\")\\n\",\n",
    "    \"        print(f\\\"Position: {state['position_status'].value}\\\")\\n\",\n",
    "    \"        print(f\\\"PnL: {state['total_pnl']:.2f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if state.get('error_message'):\\n\",\n",
    "    \"            print(f\\\"Error: {state['error_message']}\\\")\\n\",\n",
    "    \"            break\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # time.sleep(2)  # Wait before next tick\"\n",
    "   ]\n",
    "  },\n",
